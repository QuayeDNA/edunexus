{
  "name": "edunexus",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "db:generate": "pnpm --filter @edunexus/database generate",
    "db:migrate": "pnpm --filter @edunexus/database migrate",
    "db:seed": "pnpm --filter @edunexus/database seed"
  },
  "devDependencies": {
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.5.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=24"
  }
}
