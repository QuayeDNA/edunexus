# EduNexus Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ─── Supabase (required) ──────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → Data API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Service role key — only needed for the seed script (npm run seed).
# NEVER expose this in client-side code or commit it.
# Find it in: Supabase Dashboard → Project Settings → Data API → Service Role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# ─── Paystack (for online fee payments) ──────────────────────────────────────
# Get from your Paystack dashboard: Settings → API Keys
VITE_PAYSTACK_PUBLIC_KEY=

# ─── App meta ─────────────────────────────────────────────────────────────────
VITE_APP_NAME=EduNexus
VITE_APP_VERSION=1.0.0
