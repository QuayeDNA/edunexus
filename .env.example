# Database
DATABASE_URL="postgres://edunexus:edunexus_dev@localhost:5432/edunexus_dev"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth
AUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Storage provider: local, cloudinary, or s3
STORAGE_PROVIDER=local

# Local storage (dev/test)
STORAGE_LOCAL_PATH=.edunexus/storage/local

# Cloudinary (preview/staging)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# S3-compatible storage (production)
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=edunexus
STORAGE_REGION=us-east-1

# Paystack (dev/test keys)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxx"
PAYSTACK_SECRET_KEY="sk_test_xxxxxxxx"

# Email (Resend)
RESEND_API_KEY="re_xxxxxxxx"

# SMS (Africa's Talking)
AT_API_KEY="xxxxxxxx"
AT_USERNAME="sandbox"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_CONSOLE_URL="http://console.localhost:3000"
